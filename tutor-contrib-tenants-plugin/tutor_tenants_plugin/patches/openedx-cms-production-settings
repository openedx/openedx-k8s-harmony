{%- for host in HARMONY_MULTITENANT_ADDITIONAL_DOMAINS %}
{%- if 'proxy' in host and host.proxy == "cms:8000" %}
ALLOWED_HOSTS.append("{{host.domain}}")
CORS_ORIGIN_WHITELIST.append("{% if ENABLE_HTTPS %}https{% else %}http{% endif %}://{{ host.domain }}")
CORS_ORIGIN_WHITELIST.append("{% if ENABLE_HTTPS %}https{% else %}http{% endif %}://{{ host.mfe_domain }}")
CSRF_TRUSTED_ORIGINS.append("http{% if ENABLE_HTTPS %}s{% endif %}://{{host.mfe_domain}}")
{%- endif %}
{%- endfor %}
